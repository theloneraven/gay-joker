void e750_010_99_end_init_hook()
{
    SET_COUNT(104, 0);
    SET_COUNT(105, 0);
    SET_COUNT(106, 0);
    SET_COUNT(107, 0);
    SET_COUNT(108, 0);
    SET_COUNT(109, 0);
    SET_COUNT(110, 0);
    SET_COUNT(111, 0);
    SET_COUNT(60, 0);
    BIT_OFF(3824);
    BIT_OFF(3825);
    BIT_OFF(3826);
    BIT_OFF(3827);
    BIT_OFF(3828);
    BIT_OFF(3829);
    BIT_OFF(3830);
    BIT_OFF(3831);
    BIT_OFF(3832);
    BIT_OFF(3833);
    BIT_OFF(3834);
    BIT_OFF(3835);
