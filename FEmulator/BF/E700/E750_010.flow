    if (((BIT_CHK(3798) == 1) && (CMM_GET_LV(15) == 10)) && (eventMinor != 6)) // kawakami
    {
        BIT_ON(3832); // section 1 id 760
        
        if (GET_COUNT(104) == 0)
        {
            SET_COUNT(104, 8);
        }
        else if (GET_COUNT(105) == 0)
        {
            SET_COUNT(105, 8);
        }
        else if (GET_COUNT(106) == 0)
        {
            SET_COUNT(106, 8);
        }
        else if (GET_COUNT(107) == 0)
