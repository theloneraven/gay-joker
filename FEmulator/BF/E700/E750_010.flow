        if (GET_COUNT(104) == 0)
        {
            SET_COUNT(104, 5);
        }
        else if (GET_COUNT(105) == 0)
        {
            SET_COUNT(105, 5);
        }
        else if (GET_COUNT(106) == 0)
        {
            SET_COUNT(106, 5);
        }
        else if (GET_COUNT(107) == 0)
        {
            SET_COUNT(107, 5);
        }
        else if (GET_COUNT(108) == 0)
        {
            SET_COUNT(108, 5);
        }

