        }
        else if (GET_COUNT(109) == 0)
        {
            SET_COUNT(109, 9);
        }
        else if (GET_COUNT(110) == 0)
        {
            SET_COUNT(110, 9);
        }
        else if (GET_COUNT(111) == 0)
        {
            SET_COUNT(111, 9);
        }
        else if (GET_COUNT(199) == 0)
        {
            SET_COUNT(199, 9);
        }
    }

    if (BIT_CHK(3789) && CMM_GET_LV(5) == 10 && eventMinor != 12) // yusuke
    {
        BIT_ON(3835); // section 1 id 763, leaving a gap between this and the chihaya flag so its easier to copypaste between og and royal cheating event
        
        if (GET_COUNT(104) == 0)
        {
