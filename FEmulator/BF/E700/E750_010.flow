    if (((BIT_CHK(3797) == 1) && (CMM_GET_LV(14) == 10)) && (eventMinor != 5)) // takemi
    {
        BIT_ON(3831); // section 1 id 759
        
        if (GET_COUNT(104) == 0)
        {
