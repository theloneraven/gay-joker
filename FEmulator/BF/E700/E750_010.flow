// asset ids in evt are 33 for yusuke, 34 for ryuji, 35 for mishima
void e750_010_00_init_hook()
{
    int eventMinor;
    SET_COUNT(104, 0);
    SET_COUNT(105, 0);
    SET_COUNT(106, 0);
    SET_COUNT(107, 0);
    SET_COUNT(108, 0);
    SET_COUNT(109, 0);
    SET_COUNT(110, 0);
    SET_COUNT(111, 0);
    SET_COUNT(60, 0);
    BIT_OFF(3824);
    BIT_OFF(3825);
    BIT_OFF(3826);
    BIT_OFF(3827);
    BIT_OFF(3828);
    BIT_OFF(3829);
    BIT_OFF(3830);
    BIT_OFF(3831);
    BIT_OFF(3832);
    BIT_OFF(3833);
    BIT_OFF(3834);
    BIT_OFF(3835);
    BIT_OFF(3836);
    BIT_OFF(3837);
    BIT_OFF(3838);
    BIT_OFF(3839);
    eventMinor = GET_COUNT(62); // minor id for which valentines date was seen

    // new counts for tracking guys
    // these should all be counts whose values are invisible & irrelevant in the epilogue, eg. special action turn counters
    SET_COUNT(199, 0);
    SET_COUNT(200, 0);
    SET_COUNT(201, 0);
    
    if (GET_COUNT(62) == 9) // saw platonic event
    {
        BIT_ON(3839);
    }

    
    if (((BIT_CHK(3794) == 1) && (CMM_GET_LV(7) == 10)) && (eventMinor != 2)) // ann
    {
        BIT_ON(3825); // section 1 id 753
        SET_COUNT(104, 1);
    }

    
    if (((BIT_CHK(3792) == 1) && (CMM_GET_LV(3) == 10)) && (eventMinor != 0)) // makoto
    {
        BIT_ON(3826); // section 1 id 754
        
        if (GET_COUNT(104) == 0)
        {
            SET_COUNT(104, 2);
        }
        else 
        {
            SET_COUNT(105, 2);
        }

    }

    
    if (((BIT_CHK(3793) == 1) && (CMM_GET_LV(4) == 10)) && (eventMinor != 1)) // haru
    {
        BIT_ON(3827); // section 1 id 755
        
        if (GET_COUNT(104) == 0)
        {
            SET_COUNT(104, 3);
        }
        else if (GET_COUNT(105) == 0)
        {
            SET_COUNT(105, 3);
        }
        else if (GET_COUNT(106) == 0)
        {
            SET_COUNT(106, 3);
        }

