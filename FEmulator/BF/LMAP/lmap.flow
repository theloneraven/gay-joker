import("lmap.msg");

void lmap_cancel_hook()
{
    int fldMajor;
    int fldMinor;
    int fldSub;
    int commuId;
    fldMajor = FLD_GET_MAJOR();
    fldMinor = FLD_GET_MINOR();
    fldSub = FLD_GET_DIV_INDEX();
    
    if ((fldMajor == 20) && (fldMinor == 3))
    {
        FLD_LOCAL_FLAG_ON((49152 + 2));
    }
    else if ((fldMajor == 10) && (fldMinor == 13))
    {
        FLD_LOCAL_FLAG_ON((49152 + 2));
    }
    else if ((fldMajor == 20) && (fldMinor == 12))
    {
        FLD_LOCAL_FLAG_ON((49152 + 2));
    }
    else if ((fldMajor == 20) && (fldMinor == 11))
    {
        FLD_LOCAL_FLAG_ON((49152 + 2));
    }
    else if ((fldMajor == 20) && (fldMinor == 5))
    {
        FLD_LOCAL_FLAG_ON((49152 + 2));
    }
    else if ((fldMajor == 2) && (fldMinor == 1))
    {
        FLD_LOCAL_FLAG_ON((49152 + 2));
    }

    
    if (BIT_CHK(4607))
    {
        commuId = GET_COUNT(61);
        
        if (commuId == 8)
        {
            MSG_WND_DSP();
            MSG(MSG_RYUJI_SPOT_CANCEL, 0);
            MSG_WND_CLS();
        }
        else if ((commuId == 7) || (commuId == 25))
        {
            MSG_WND_DSP();
            MSG(MSG_ANNE_SPOT_CANCEL, 0);
            MSG_WND_CLS();
        }
        else if (commuId == 5)
        {
            MSG_WND_DSP();
            MSG(MSG_YUSUKE_SPOT_CANCEL, 0);
            MSG_WND_CLS();
        }
        else if ((commuId == 3) || (commuId == 23))
        {
            MSG_WND_DSP();
            MSG(MSG_MAKOTO_SPOT_CANCEL, 0);
            MSG_WND_CLS();
        }
        else if ((commuId == 10) || (commuId == 26))
        {
            MSG_WND_DSP();
            MSG(MSG_FUTABA_SPOT_CANCEL, 0);
            MSG_WND_CLS();
        }
        else if ((commuId == 4) || (commuId == 24))
        {
            MSG_WND_DSP();
            MSG(MSG_HARU_SPOT_CANCEL, 0);
            MSG_WND_CLS();
        }
        else if (commuId == 9)
        {
            MSG_WND_DSP();
            MSG(MSG_AKECHI_SPOT_CANCEL, 0);
            MSG_WND_CLS();
        }

        SET_COUNT(61, 0);
    }

}

