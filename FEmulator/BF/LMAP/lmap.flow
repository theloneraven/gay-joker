void go_spot_coop_hook()
{
    int commuId;
    int trainFare;
    int var184;
    int var185;
    int var186;
    int fldMajor;
    int fldMinor;
    int fldSub;
    int entranceId;
    commuId = GET_COUNT(61);
    FLD_SET_LOCAL_COUNT((49152 + 10), 0);
    trainFare = FLD_LMAP_GET_FARE(0);
    
    if (commuId == 8)
    {
        proc_SPOT_SET_RYUJI();
    }
    else if ((commuId == 7) || (commuId == 25))
    {
        proc_SPOT_SET_ANNE();
    }
    else if (commuId == 5)
    {
        proc_SPOT_SET_YUSUKE();
    }
    else if ((commuId == 3) || (commuId == 23))
    {
        proc_SPOT_SET_MAKOTO();
    }
    else if ((commuId == 10) || (commuId == 26))
    {
        proc_SPOT_SET_FUTABA();
    }
    else if ((commuId == 4) || (commuId == 24))
    {
        proc_SPOT_SET_HARU();
    }
    else if ((commuId == 33) || (commuId == 34))
    {
        proc_SPOT_SET_KASUMIRE();
    }
    else if (commuId == 9)
    {
        proc_SPOT_SET_AKECHI();
    }

    SET_COUNT(376, sVar0);
    
    if (BIT_CHK(1008) == 1)
    {
        SYNC();
    }
    else 
    {
        proc_fare();
    }

    FLD_LMAP_FADE(0);
    MSG_WND_DSP();
    MSG(sVar1, 0);
    MSG_WND_CLS();
    Fld_FadeOut_Subway();
    FLD_PANEL_MAP_PROC_END(0);
    var184 = FLD_GET_LOCAL_COUNT((49152 + 10));
    var185 = (var184 / 1000);
    var186 = REM(var184, 1000);
    CALL_EVENT(var185, var186);
    TROPHY_REQUEST(116, 0);
    SYNC();
    BIT_OFF(1288);
    BIT_OFF(4896);
    BIT_OFF(4607);
    FLD_SET_LOCAL_COUNT((49152 + 10), 0);
    SET_COUNT(376, 0);
    
    if ((BIT_CHK(5006) == 0) && (BIT_CHK(5005) == 0))
    {
        
        if (CHK_DAYS_STARTEND(4, 1, 4, 3))
        {
            
            if ((commuId == 3) || (commuId == 23))
            {
                
                if (BIT_CHK(3088) == 0)
                {
                    fldMajor = 2;
                    fldMinor = 2;
                    fldSub = 202;
                    entranceId = 2;
                }
                else 
                {
                    fldMajor = 2;
                    fldMinor = 1;
                    fldSub = 202;
                    entranceId = 0;
                }

            }
            else if ((commuId == 4) || (commuId == 24))
            {
                fldMajor = 2;
                fldMinor = 5;
                fldSub = 203;
                entranceId = 0;
            }
            else if (commuId == 5)
            {
                fldMajor = 1;
                fldMinor = 2;
                fldSub = 204;
                entranceId = 0;
            }
            else if ((commuId == 7) || (commuId == 25))
            {
                
                if (BIT_CHK(3880) == 0)
                {
                    fldMajor = 2;
                    fldMinor = 6;
                    fldSub = 206;
                    entranceId = 0;
                }
                else 
                {
                    fldMajor = 1;
                    fldMinor = 4;
                    fldSub = 206;
                    entranceId = 0;
                }

            }
            else if (commuId == 8)
            {
                
                if (BIT_CHK(3088) == 0)
                {
                    fldMajor = 2;
                    fldMinor = 2;
                    fldSub = 207;
                    entranceId = 1;
                }
                else 
                {
                    fldMajor = 18;
                    fldMinor = 0;
                    fldSub = 207;
                    entranceId = 0;
                }

            }
            else if ((commuId == 10) || (commuId == 26))
            {
                fldMajor = 9;
                fldMinor = 2;
                fldSub = 209;
                entranceId = 0;
            }
            else 
            {
                CALL_CALENDAR();
                return;
            }

            Fld_FadeOut_CallField();
            CALL_FIELD(fldMajor, fldMinor, fldSub, entranceId);
            return;
        }

    }

    CALL_CALENDAR();
}

