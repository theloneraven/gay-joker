void SUB_COOP_RANKUP_EVT_hook()
{
    int rank;
    rank = 0;
    CMM_SETUP_EVENT(0, sVar0);
    CMM_LVUP(sVar0);
    rank = CMM_GET_LV(sVar0);
    
    if (rank == 2)
    {
        MSG_WND_DSP();
        MSG(MSG_C08_YES_01_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 3)
    {
        MSG_WND_DSP();
        MSG(MSG_C08_YES_02_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 4)
    {
        MSG_WND_DSP();
        MSG(MSG_C08_YES_03_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 5)
    {
        MSG_WND_DSP();
        MSG(MSG_C08_YES_04_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 6)
    {
        MSG_WND_DSP();
        MSG(MSG_C08_YES_05_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 7)
    {
        MSG_WND_DSP();
        MSG(MSG_C08_YES_06_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 8)
    {
        
        if (FLD_GET_MAJOR() == 1)
        {
            MSG_WND_DSP();
            MSG(MSG_C08_YES_07_00, 0);
            MSG_WND_CLS();
        }
        else 
        {
            MSG_WND_DSP();
            MSG(MSG_C08_YES_07_00_KCJ, 0);
            MSG_WND_CLS();
        }

    }

    MSG_WND_DSP();
    
    if (rank < 4)
    {
        MSG(MSG_MORGANA_COOP_ESCAPE, 0);
    }
    else if (rank == 8)
    {
        
        if (BIT_CHK(3898) == 0)
        {
            MSG(MSG_MORGANA_COOP_ESCAPE_, 0);
        }
        else 
        {
            MSG(MSG_MORGANA_COOP_ESCAPE__2, 0);
        }

    }

    MSG_WND_CLS();
    SUB_COOP_TABLE_EVENT_START();
}

void SUB_COOP_GENERAL_EVT_CHECK_hook()
{
    int selChoice;
    
    if (sVar2 == 0)
    {
        selChoice = (selChoice + 1);
    }

    
    if (BIT_CHK(3786) == 1)
    {
        
        if (selChoice != 0)
        {
            MSG_WND_DSP();
            MSG(MSG_C08_REV_SPOT_00_00, 0);
            selChoice = SEL(SEL_C08_REV_SPOT_00_01);
            MSG_WND_CLS();
            
            if (selChoice == 0)
            {
                sVar2 = 5;
                SUB_COOP_LOVERS_EVT();
            }
            else if (selChoice == 1)
            {
                sVar2 = 2;
                SUB_COOP_SPOT_EVT_REV();
            }
            else 
            {
                sVar2 = 4;
                SUB_COOP_GENERAL_EVT_REV();
            }

        }
        else 
        {
            sVar2 = 4;
            SUB_COOP_GENERAL_EVT_REV();
        }

    }
    else if (sVar1 != 0)
    {
        MSG_WND_DSP();
        MSG(MSG_C08_SPOT_00_00, 0);
        selChoice = SEL(SEL_C08_SPOT_00_01);
        MSG_WND_CLS();
        
        if (selChoice == 0)
        {
            sVar2 = 2;
            SUB_COOP_SPOT_EVT();
        }
        else 
        {
            sVar2 = 4;
            SUB_COOP_GENERAL_EVT();
        }

    }
    else 
    {
        sVar2 = 4;
        SUB_COOP_GENERAL_EVT();
    }
}

