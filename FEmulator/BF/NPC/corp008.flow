void SUB_BEGIN_MSG_AKECHI_hook()
{
    int fldScript;
    int var5;
    int var6;
    int rank;
    fldScript = FLD_SCRIPT_READ(2500, 0, 0);
    FLD_SCRIPT_READ_SYNC(fldScript);
    FLD_SCRIPT_EXEC(fldScript, 0);
    FLD_SCRIPT_FREE(fldScript);
    var5 = GET_COUNT(56);
    var5 = (var5 / 10);
    var6 = GET_COUNT(56);
    var6 = REM(var6, 10);
    rank = CMM_GET_LV(sVar0);
    
    if (((var5 == 6) && (var6 == 5)) && BIT_CHK(1180))
    {
        MSG_WND_DSP();
        MSG(MSG_C02_BEGIN_D06_50_01, 0);
        MSG_WND_CLS();
        
        if (BIT_CHK(3592))
        {
            MSG_WND_DSP();
            MSG(MSG_C08_BEGIN_COOPNG_00, 0);
            MSG_WND_CLS();
            sVar2 = -1;
        }

    }
    else if (var5 == 10)
    {
        SUB_BEGIN_MSG_AKECHI_THEATER();
    }

}

