void SUB_COOP_FIGHT_EVT()
{
    NET_SET_NIGHT_ACTION(93);
    Fld_FadeOut_CallEvent();
    BIT_ON(12308);
    BIT_ON(12310);
    FLD_PARTY_SAVE();
    PARTY_OUT(2);
    PARTY_OUT(3);
    PARTY_OUT(4);
    PARTY_OUT(5);
    PARTY_OUT(6);
    PARTY_OUT(8);
    PARTY_OUT(7);
    PARTY_OUT(9);
    PARTY_OUT(10);
    CALL_EVENTBATTLE(726, 100, 870);
    BIT_ON(3898);
    
    if (BIT_CHK(11572) == 0)
    {
        BIT_ON(3787);
        CALL_EVENT(726, 101);
        
        if (BIT_CHK(3786) == 1)
        {
            CALL_EVENT(726, 104);
        }
        else if (BIT_CHK(3786) == 0)
        {
            CALL_EVENT(726, 102);
        }

        BIT_OFF(3997);
        BIT_OFF(4072);
    }
    else 
    {
        CALL_EVENT(726, 103);
        FLD_PARTY_LOAD();
        BIT_OFF(12308);
        BIT_OFF(12310);
        BIT_OFF(12309);
        BIT_OFF(4896);
    }

    FLD_PARTY_LOAD();
    BIT_OFF(12308);
    BIT_OFF(12310);
    BIT_OFF(12309);
    BIT_OFF(4896);
    CALL_CALENDAR();
}

