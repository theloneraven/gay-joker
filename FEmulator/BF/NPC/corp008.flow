    }
}

void SUB_COOP_TABLE_EVENT_START_hook()
{
    int rank;
    
    if (sVar2 == 1)
    {
        rank = CMM_GET_LV(sVar0);
    }
    else 
    {
        rank = 0;
    }

    SUB_COOP_EVT_SET();
    Fld_FadeOut_CallEvent();
    
    if (rank != 8)
    {
        CMM_EXEC_EVENT();
    }
    else 
    {
        BIT_ON(12308);
        BIT_ON(12310);
        FLD_PARTY_SAVE();
        PARTY_OUT(2);
        PARTY_OUT(3);
        PARTY_OUT(4);
        PARTY_OUT(5);
        PARTY_OUT(6);
        PARTY_OUT(8);
        PARTY_OUT(7);
        PARTY_OUT(9);
        PARTY_OUT(10);
        CALL_EVENTBATTLE(726, 82, 828);
        BIT_ON(3898);
        
        if (BIT_CHK(11572) == 0)
        {
            BIT_ON(3899);
            CALL_EVENT(726, 83);
            CALL_EVENT(726, 84);
            BIT_OFF(3997);
            BIT_OFF(4072);
        }
        else 
        {
            CALL_EVENT(726, 86);
            
            if (BIT_CHK(3996) == 0)
            {
                CALL_EVENT(881, 103);
            }

            CMM_SET_LV(sVar0, 7);
            FLD_PARTY_LOAD();
            BIT_ON(3997);
            BIT_OFF(3899);
            BIT_OFF(12308);
            BIT_OFF(12310);
            BIT_OFF(12309);
            SUB_COOP_EVT_RESET();
            return;
        }

        FLD_PARTY_LOAD();
        BIT_OFF(3899);
        BIT_OFF(12308);
        BIT_OFF(12310);
        BIT_OFF(12309);
    }

    
    if (rank == 4)
    {
        CALL_EVENT(726, 43);
        BIT_ON(5133);
    }
    else if (rank == 6)
    {
        CALL_EVENT(726, 63);
    }
    else if (rank == 7)
    {
        CALL_EVENT(726, 73);
    }

    SUB_COOP_RANKUP_AFTER_AKECHI();
    SUB_COOP_EVT_RESET();
}

