import("corp018.msg");

void SUB_COOP_START_MORGANA_MSG_hook()
{
    int rank;
    rank = CMM_GET_LV(sVar0);
    
    if (CMM_CHK_LVUP(sVar0) == 1)
    {
        
        if (rank == 2)
        {
            MSG_WND_DSP();
            MSG_MIND(MND_COOP_RANKUP_OK_FIRST, 0);
            MSG_WND_CLS();
        }
        else if ((rank == 6) && (BIT_CHK(3978) == 0))
        {
            MSG_WND_DSP();
            MSG_MIND(MND_COOP_RANKUP_QUEST, 0);
            MSG_WND_CLS();
        }
        else 
        {
            MSG_WND_DSP();
            MSG_MIND(MND_COOP_RANKUP_OK, 0);
            MSG_WND_CLS();
        }

    }
    else if (CMM_GET_LV(sVar0) == 10)
    {
        
        if (BIT_CHK(3791))
        {
            MSG_WND_DSP();
            MSG_MIND(MND_COOP_RANK_MAX_01, 0);
            MSG_WND_CLS();
        }
        else 
        {
            MSG_WND_DSP();
            MSG_MIND(MND_COOP_RANK_MAX_00, 0);
            MSG_WND_CLS();
        }

    }
    else 
    {
        MSG_WND_DSP();
        MSG_MIND(MND_COOP_RANKUP_NG, 0);
        MSG_WND_CLS();
    }

    MSG_WND_DSP();
    
    if (BIT_CHK(95) == 1)
    {
        MSG(MSG_COOP_CHECK_SHIDOU, 0);
    }

    
    if ((rank == 6) && BIT_CHK(3978))
    {
        MSG(MSG_COOP_CHECK_DAY_6, 0);
    }
    else 
    {
        MSG(MSG_COOP_CHECK_DAY, 0);
    }
}

void SUB_TALK_COOP_EVT_hook()
{
    int rank;
    int var19;
    int var20;
    rank = 0;
    var19 = 0;
    CMM_SETUP_EVENT(0, sVar0);
    CMM_LVUP(sVar0);
    rank = CMM_GET_LV(sVar0);
    
    if (rank == 2)
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_01_00, 0);
        MSG_WND_CLS();
        MSG_WND_DSP();
        MSG(MSG_MORGANA_COOP_ESCAPE, 0);
        MSG_WND_CLS();
    }
    else if (rank == 3)
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_02_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 4)
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_03_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 5)
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_04_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 6)
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_05_00, 0);
        MSG_WND_CLS();
    }
    else if (rank == 7)
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_06_01, 0);
        MSG_WND_CLS();
    }
    else if (rank == 8)
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_07_00, 0);
        MSG_WND_CLS();
        MSG_WND_CLS();
        var20 = FLD_NPC_GET_RESHND();
        MDL_ICON(var20, 15);
        FLD_COMSE_PLAY(3113);
        MSG_WND_DSP();
        MSG(MSG_C18_YES_07_01, 0);
        MSG_WND_CLS();
        Fld_FadeOut_CutChange();
        WAIT(30);
        Fld_FadeIn_Default();
        MSG_WND_DSP();
        MSG(MSG_C18_YES_07_02, 0);
        MSG_WND_CLS();
    }
    else if (rank == 9)
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_08_00, 0);
        MSG_WND_CLS();
    }
    else if (BIT_CHK(3791) == 1)
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_09_01, 0);
        MSG_WND_CLS();
    }
    else 
    {
        MSG_WND_DSP();
        MSG(MSG_C18_YES_09_00, 0);
        MSG_WND_CLS();
    }

    SUB_COOP_EVT_SET();
    
    if (rank == 6)
    {
        
        if (BIT_CHK(10149) == 0)
        {
            BIT_ON(10149);
            FLD_SHOW_NEW_SPOT_SYNC_MODE(17);
            MSG_WND_DSP();
            MSG_PERFORMANCE(MSG_SPOT_OPEN_INOKASHIRA);
            MSG_WND_CLS();
            
            if (BIT_CHK(4054) == 0)
            {
                CALL_TUTORIAL(2, 0x10);
                BIT_ON(4054);
            }

            FLD_SHOW_NEW_SPOT_SYNC_EXIT();
        }

        Fld_FadeOut_Subway();
        var19 = 1;
    }
    else if (rank == 7)
    {
        Fld_FadeOut_Subway();
    }
    else if (rank == 10)
    {
        Fld_FadeOut_Subway();
    }
    else 
    {
        Fld_FadeOut_CallEvent();
    }

    if (BIT_CHK(3791)) { CALL_EVENT(718, 101); }
    else { CMM_EXEC_EVENT(); }
    
    if (var19 == 1)
    {
        TROPHY_REQUEST(116, 0);
    }

    SUB_COOP_RANKUP_AFTER_MISHIMA();
    SUB_COOP_EVT_RESET();
}

void SUB_COOP_EVT_SET_hook()
{
    BIT_OFF(4082);
    BIT_ON(4401);
    
    if (BIT_CHK(3791))
    {
        BIT_ON(1288);
    }

    NET_SET_NIGHT_ACTION(17);
}