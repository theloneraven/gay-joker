        || CHAT_CHECK_SWITCH(1338)  // ryuji
        || CHAT_CHECK_SWITCH(1336)) // mishima
    {
        wentOnDate = 1;
    }

    // cheating event
    if (((numBitches == 9) && (BIT_CHK(4041) == 0)) && (wentOnDate == 0))
    {
        CALL_EVENT(750, 11);
    }
    else if ((numBitches == 0) || ((numBitches == 1) && (wentOnDate == 1)))
    {
        SYNC();
    }
    else 
    {
        CALL_EVENT(750, 10);
    }

    BIT_ON(2113);
    SET_NEXT_DAY(3, 19, 0);

}


