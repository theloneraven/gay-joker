    if (BIT_CHK(3800) && CMM_GET_LV(18) == 10)
    {
        numBitches = (numBitches + 1);
    }


    if (BIT_CHK(3791) && CMM_GET_LV(19) == 10) // mishima
    {
        numBitches = (numBitches + 1);
    }


    if (BIT_CHK(3789) && CMM_GET_LV(5) == 10) // yusuke
    {
        numBitches = (numBitches + 1);
    }


    if (BIT_CHK(3785) && CMM_GET_LV(8) == 10) // ryuji
    {
        numBitches = (numBitches + 1);
    }

    if (CHAT_CHECK_SWITCH(400)
        || CHAT_CHECK_SWITCH(428)
        || CHAT_CHECK_SWITCH(474)
        || CHAT_CHECK_SWITCH(517)
        || CHAT_CHECK_SWITCH(520)
