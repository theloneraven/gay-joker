import("../chat_common.flow");

void sdl03_13_AM_A_RE_hook()
{
    int bitchesBitfield;
    bitchesBitfield = 0;

    if (BIT_CHK(3792) && CMM_GET_LV(3) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 1);
    }


    if (BIT_CHK(3793) && CMM_GET_LV(4) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 2);
    }


    if (BIT_CHK(3794) && CMM_GET_LV(7) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 4);
    }


    if (BIT_CHK(3795) && CMM_GET_LV(10) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 8);
    }


    if (BIT_CHK(3796) && CMM_GET_LV(11) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 0x10);
    }


    if (BIT_CHK(3797) && CMM_GET_LV(14) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 0x20);
    }


    if (BIT_CHK(3798) && CMM_GET_LV(15) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 0x40);
    }


    if (BIT_CHK(3799) && CMM_GET_LV(0x10) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 0x80);
    }


    if (BIT_CHK(3800) && CMM_GET_LV(18) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 0x0100);
    }


    if (BIT_CHK(3816) && CMM_GET_LV(33) == 10)
    {
        bitchesBitfield = (bitchesBitfield + 0x0200);
    }


    if (BIT_CHK(3791) && CMM_GET_LV(19) == 10) // mishima
    {
        bitchesBitfield = (bitchesBitfield + 0x0400);
    }


    if (BIT_CHK(3789) && CMM_GET_LV(5) == 10) // yusuke
    {
        bitchesBitfield = (bitchesBitfield + 0x0800);
    }


    if (BIT_CHK(3785) && CMM_GET_LV(8) == 10) // ryuji
    {
        bitchesBitfield = (bitchesBitfield + 0x1000);
    }


    if (bitchesBitfield != 0)
    {
        BIT_ON(3819);
    }

