void RYUJI_RANKUP_INVITE_CHAT_hook()
{
    int ryujiRank;
    int chatId;

    if (BIT_CHK(3735)) { return; }

    ryujiRank = CMM_GET_LV(GET_INVITE_WORK(1));
    chatId = -1;

    if ((ryujiRank == 4) && (CHK_DAYS_STARTEND(4, 9, 5, 1) == 1)) { return; }
    if (ryujiRank == 6) { return; }
    
    if (ryujiRank == 9 && BIT_CHK(3785) == 1) { chatId = 1314; }
    else { chatId = 474 + ryujiRank; }

    if (chatId >= 0)
    {
        CALL_CHAT_ARRIVAL(chatId);
        BIT_ON(4071);
        BIT_ON(4358);
        SET_COUNT(51, (GET_COUNT(51) + 1));
    }
}

void YUSUKE_RANKUP_INVITE_CHAT_hook()
{
    int yusukeRank;
    int chatId;

    if (BIT_CHK(3732)) { return; }

    yusukeRank = CMM_GET_LV(GET_INVITE_WORK(1));
    chatId = -1;

    if (yusukeRank == 5)
    {
        if (BIT_CHK(3870)) { return; }
    }
    
    if (yusukeRank == 9 && BIT_CHK(3789)) { chatId = 1312; }
    else { chatId = (431 + yusukeRank); }

    if (chatId >= 0)
    {
        CALL_CHAT_ARRIVAL(chatId);
        BIT_ON(4068);
        BIT_ON(4355);
        SET_COUNT(51, (GET_COUNT(51) + 1));
    }
}

void MISHIMA_RANKUP_INVITE_CHAT_hook()
{
    int mishimaRank;
    int chatId;

    if (BIT_CHK(3746) || BIT_CHK(11791)) { return; }

    mishimaRank = CMM_GET_LV(GET_INVITE_WORK(1));
    chatId = -1;

    if ((mishimaRank >= 2) && (mishimaRank <= 4)) { chatId = (639 + mishimaRank); }
    else if (mishimaRank == 5) { chatId = 646; }
    else if (mishimaRank == 6)
    {
        if (BIT_CHK(3978)) { chatId = 645; }
        else if (!BIT_CHK(3976))
        {
            chatId = 644;
            BIT_ON(3976);
        }
    }
    else if (mishimaRank == 9 && BIT_CHK(3791)) { chatId = 1320; }
    else { chatId = (640 + mishimaRank); }

    if (chatId >= 0)
    {
        CALL_CHAT_ARRIVAL(chatId);
        BIT_ON(4082);
        BIT_ON(4369);
        SET_COUNT(51, (GET_COUNT(51) + 1));
    }
}

void AKECHI_RANKUP_INVITE_CHAT()
{
    int rank;
    int chatId;
    
    if (BIT_CHK(3736)) { return; }

    rank = CMM_GET_LV(GET_INVITE_WORK(1));
    chatId = -1;
    
    if (rank == 2)
    {
        if (GET_PC_PARAM_LV(1, 0) < 3 || GET_PC_PARAM_LV(1, 1) < 3) { return; }
    }

    if (rank == 5)
    {
        if (CMM_CHK_LVUP(GET_INVITE_WORK(1))) { return; }
    }
    
    if (rank == 6)
    {
        if (CHK_DAYS_STARTEND(4, 1, 11, 1) || GET_PC_PARAM_LV(1, 0) < 4) { return; }
    }
    
    if (rank == 7)
    {
        if (!BIT_CHK(11831) || BIT_CHK(3897)) { return; }
    }
    else if (BIT_CHK(3786)) { chatId = 1316; }
    else { chatId = 489 + rank; }
    
    if (chatId >= 0)
    {
        CALL_CHAT_ARRIVAL(chatId);
        BIT_ON(4072);
        BIT_ON(4359);
        SET_COUNT(51, (GET_COUNT(51) + 1));
    }
}

